# Copy this file to .env and fill in the values. .env is gitignored.

# Tulsa Gays Facebook Page (Graph API)
TULSAGAYS_PAGE_ID=1086906044497675
TULSAGAYS_PAGE_ACCESS_TOKEN=

# HHHH Facebook Page (Graph API)
# Find the page id at facebook.com/<page-handle> -> About -> Page transparency,
# or in Meta Business Suite -> the page's settings -> Page info.
# Generate a permanent page access token by getting a short-lived user token
# from the Graph API Explorer (logged in as a HHHH page admin) and then:
#   curl -s 'https://graph.facebook.com/v25.0/<PAGE_ID>?fields=access_token&access_token=<USER_TOKEN>'
HHHH_PAGE_ID=
HHHH_PAGE_ACCESS_TOKEN=

# HHHH Facebook Group (Playwright-driven, not Graph API)
# Meta deprecated programmatic group posting in April 2024, so posts to
# the group go through a real browser. Set this to the full group URL,
# e.g. https://www.facebook.com/groups/123456789012345
# First run: python -m posting.group_post --setup  (one-time login)
HHHH_GROUP_URL=

# Instagram (existing)
META_ACCESS_TOKEN=
META_IG_USER_ID=

# Other (existing)
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
TICKETMASTER_API_KEY=
